APP_ENV=staging
PORT=3000
ADMIN_SECRET=replace-with-staging-admin-secret
MAX_MINTS=3
MINT_WINDOW_MS=60000

# Staging should use a dedicated pre-production deployment, not shared dev/test contracts.
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

HUNTY_CORE_ID=replace-with-staging-hunty-core-contract-id
REWARD_MANAGER_ID=replace-with-staging-reward-manager-contract-id
NFT_REWARD_ID=replace-with-staging-nft-reward-contract-id
